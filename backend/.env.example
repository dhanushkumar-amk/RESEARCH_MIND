# Server Configurations
HOST=127.0.0.1
PORT=8000
DEBUG=true

# Security & CORS
JWT_SECRET=researchmind-proprietary-secret-key-change-this
TOKEN_EXPIRY_DAYS=7
ACCESS_TOKEN_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=7
RESET_TOKEN_EXPIRY_MINUTES=30
VERIFICATION_CODE_EXPIRY_MINUTES=10
PASSWORD_RESET_CODE_EXPIRY_MINUTES=10
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (MongoDB)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ResearchMind?retryWrites=true&w=majority
MONGODB_DATABASE=ResearchMind

# Email (Resend - recommended)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=no-reply@send.researchmind.ai
RESEND_FROM_NAME=ResearchMind

# Email (SMTP - optional fallback)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email_username
SMTP_PASSWORD=your_email_app_password
SMTP_FROM_EMAIL=no-reply@researchmind.ai
SMTP_FROM_NAME=ResearchMind
SMTP_USE_TLS=true
FRONTEND_URL=http://localhost:5173

# LLM Providers (LiteLLM / LLMGate Router)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Object Storage (AWS S3)
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_BUCKET=researchmind-storage
AWS_REGION=us-east-1

# External Research APIs (MCP Tools)
TAVILY_API_KEY=your_tavily_api_key_here
NEWS_API_KEY=your_news_api_key_here

# Monitoring & Evaluation Stack
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=ResearchMind
MLFLOW_TRACKING_URI=http://localhost:5000
